---
import type { ImageMetadata } from 'astro';
import ShowcaseTile from './ShowcaseTile.astro';

type Discipline = 'Drawing' | 'Render' | 'Animation';

interface SplitTile {
  discipline: Discipline;
  title: string;
  image: ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  eager?: boolean;
  note?: string;
}

interface Props {
  before: SplitTile;
  after: SplitTile;
  ratio?: string;
}

const { before, after, ratio = '4 / 3' } = Astro.props;
---

<div
  class="compare-split"
  style={`--split: 50; --cs-ratio: ${ratio};`}
  data-before={before.discipline.toLowerCase()}
  data-after={after.discipline.toLowerCase()}
>
  <div class="cs-panel cs-panel--before">
    <ShowcaseTile {...before} fill />
  </div>
  <div class="cs-panel cs-panel--after">
    <ShowcaseTile {...after} fill />
  </div>
  {/* aria-valuetext is set by JS only — a static server-rendered value would
      go stale (and mislead AT) if JS never attaches; without it the native
      aria-valuenow stays correct on its own. */}
  <input
    type="range"
    class="cs-handle"
    min="20"
    max="80"
    step="5"
    value="50"
    aria-label={`Drag to compare ${before.discipline.toLowerCase()} and ${after.discipline.toLowerCase()}`}
  />
  <div class="cs-divider" aria-hidden="true">
    <span class="cs-tick"></span>
  </div>
</div>

<style>
  .compare-split {
    position: relative;
    aspect-ratio: var(--cs-ratio);
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--line);
  }

  /* Absolutely positioned (rather than grid columns) so each panel's height
     resolves against the split's own aspect-ratio box — a true definite
     value the fill tile can inherit — instead of an 'auto' grid row that
     would grow to fit the caption underneath and throw off the ratio. */
  .cs-panel {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .cs-panel--before {
    width: calc(var(--split, 50) * 1%);
  }

  .cs-panel--after {
    left: calc(var(--split, 50) * 1%);
  }

  /* Native range input drives the whole thing — full-bleed, transparent, but
     genuinely focusable/draggable/touchable across the entire height so
     keyboard, touch and screen-reader semantics are the real, free ones. */
  .cs-handle {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    cursor: ew-resize;
    z-index: 2;
  }

  .cs-handle::-webkit-slider-runnable-track {
    width: 100%;
    height: 100%;
    background: transparent;
  }

  .cs-handle::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 2rem;
    height: 100%;
    background: transparent;
    cursor: ew-resize;
  }

  .cs-handle::-moz-range-track {
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
  }

  .cs-handle::-moz-range-thumb {
    width: 2rem;
    height: 100%;
    background: transparent;
    border: none;
    cursor: ew-resize;
  }

  /* Decorative hairline + tick — purely visual, mirrors the old .pair-seam
     language, tracks the same --split value the input writes to. */
  .cs-divider {
    position: absolute;
    top: 0;
    left: calc(var(--split, 50) * 1%);
    transform: translateX(-50%);
    width: 1px;
    height: 100%;
    background: var(--line-strong);
    pointer-events: none;
    z-index: 1;
  }

  .cs-tick {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 5px var(--paper);
  }

  .cs-handle:focus-visible ~ .cs-divider .cs-tick {
    box-shadow:
      0 0 0 5px var(--paper),
      0 0 0 7px var(--accent-ink);
  }

  @media (max-width: 860px) {
    /* No cramped drag on small screens: drop the split entirely and stack
       the two tiles full-width, each back to its natural aspect-ratio. */
    .compare-split {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
      aspect-ratio: unset;
      overflow: visible;
      border: none;
      background: none;
    }

    .cs-panel {
      position: static;
      width: 100%;
      overflow: visible;
    }

    .cs-panel :global(.tile--fill) {
      height: auto;
    }

    .cs-panel :global(.tile--fill .frame) {
      aspect-ratio: var(--tile-ratio);
      height: auto;
    }

    .cs-handle,
    .cs-divider {
      display: none;
    }
  }
</style>

<script>
  // Drag/keyboard/touch on the native range input drives --split; the panel
  // widths and decorative hairline both read it straight from CSS.
  function initCompareSplit() {
    const splits = document.querySelectorAll<HTMLElement>('.compare-split:not([data-wired])');
    splits.forEach((split) => {
      split.dataset.wired = 'true';
      const input = split.querySelector<HTMLInputElement>('.cs-handle');
      if (!input) return;

      const before = split.dataset.before ?? 'before';
      const after = split.dataset.after ?? 'after';

      const update = () => {
        const value = Number(input.value);
        split.style.setProperty('--split', String(value));
        input.setAttribute('aria-valuetext', `${value}% ${before}, ${100 - value}% ${after}`);
      };

      input.addEventListener('input', update);
      // Set aria-valuetext (and normalize --split) immediately now that JS
      // owns it — see the markup comment for why it isn't server-rendered.
      update();
    });
  }

  document.addEventListener('astro:page-load', initCompareSplit);
</script>

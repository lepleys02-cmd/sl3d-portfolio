---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type Discipline = 'Drawing' | 'Render' | 'Animation';

interface Props {
  discipline: Discipline;
  title: string;
  /** Aspect ratio of the framed slot, e.g. "4 / 3", "16 / 9", "4 / 5". */
  ratio?: string;
  /** Still image (renders + drawings). */
  image?: ImageMetadata;
  alt?: string;
  widths?: number[];
  sizes?: string;
  eager?: boolean;
  /** Motion tiles: source + poster under /public. */
  video?: string;
  poster?: string;
  /** Optional one-line curatorial note shown under the caption row. */
  note?: string;
}

const {
  discipline,
  title,
  ratio = '4 / 3',
  image,
  alt,
  widths = [480, 800, 1200],
  sizes = '(max-width: 720px) 100vw, 42vw',
  eager = false,
  video,
  poster,
  note,
} = Astro.props;

// Drawings are shown matted on a sheet (contain); renders/animation bleed to the edge (cover).
const isDrawing = discipline === 'Drawing';
const isMotion = discipline === 'Animation';
---

<figure
  class:list={['tile', 'reveal', { 'tile--sheet': isDrawing, 'tile--motion': isMotion }]}
  style={`--tile-ratio: ${ratio};`}
>
  <div class="frame">
    {
      image && (
        <Image
          src={image}
          alt={alt ?? `${title} — ${discipline}`}
          widths={widths}
          sizes={sizes}
          loading={eager ? 'eager' : 'lazy'}
        />
      )
    }
    {
      video && (
        <video
          class="motion"
          data-motion
          muted
          loop
          playsinline
          preload="none"
          poster={poster}
          width="1920"
          height="1080"
          aria-label={`${title} — animation`}
        >
          <source src={video} type="video/mp4" />
        </video>
      )
    }
    {isMotion && <span class="cue" aria-hidden="true">Motion</span>}
  </div>
  <figcaption>
    <span class="cap-row">
      <span class="disc">{discipline}</span>
      <span class="ttl">{title}</span>
    </span>
    {note && <span class="note">{note}</span>}
  </figcaption>
</figure>

<style>
  .tile {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .frame {
    position: relative;
    aspect-ratio: var(--tile-ratio);
    overflow: hidden;
    background: var(--line);
  }

  /* Renders + animation: photographic, edge to edge. */
  .frame img,
  .frame .motion {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Drawings read as sheets: matted on paper-white, nothing cropped. */
  .tile--sheet .frame {
    background: var(--surface);
    border: 1px solid var(--line-strong);
    padding: clamp(0.6rem, 1.6vw, 1.4rem);
  }

  .tile--sheet .frame img {
    object-fit: contain;
  }

  .frame img {
    transition: transform 700ms var(--ease-out);
  }

  .tile:not(.tile--sheet):hover .frame img {
    transform: scale(1.035);
  }

  .motion {
    opacity: 0;
    transition: opacity 500ms var(--ease-out);
  }

  .motion.is-live {
    opacity: 1;
  }

  /* Small motion badge, quiet — hairline pill, one accent tick. */
  .cue {
    position: absolute;
    left: 0.85rem;
    bottom: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 0.28em 0.7em;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    border: 1px solid var(--line-strong);
    backdrop-filter: none;
  }

  .cue::before {
    content: '';
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--accent);
  }

  figcaption {
    display: block;
    padding-top: 0.75rem;
  }

  .cap-row {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
  }

  .note {
    display: block;
    margin-top: 0.45rem;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 52ch;
  }

  .disc {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }

  .ttl {
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.3;
    text-wrap: balance;
  }

  @media (prefers-reduced-motion: reduce) {
    .frame img {
      transition: none;
    }
    /* Poster stays; motion layer never fades in. */
    .motion.is-live {
      opacity: 0;
    }
  }
</style>

<script>
  // Below-fold animation tiles: nothing downloads until the tile is near the
  // viewport, then it plays; it pauses when it scrolls away. Reduced-motion
  // users keep the poster frame. Only in-view tiles ever play, so at most a
  // couple run at once.
  function initMotion() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const videos = document.querySelectorAll<HTMLVideoElement>('video[data-motion]:not([data-wired])');
    if (!videos.length) return;

    if (!('IntersectionObserver' in window)) {
      videos.forEach((v) => {
        v.dataset.wired = 'true';
        v.classList.add('is-live');
        v.play().catch(() => {});
      });
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const v = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            v.classList.add('is-live');
            v.play().catch(() => v.classList.remove('is-live'));
          } else {
            v.pause();
          }
        }
      },
      { threshold: 0.35 }
    );

    videos.forEach((v) => {
      v.dataset.wired = 'true';
      io.observe(v);
    });
  }

  document.addEventListener('astro:page-load', initMotion);
</script>

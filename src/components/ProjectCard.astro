---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index: number;
  cover: ImageMetadata;
  /** Full-width cards get larger responsive image slots. */
  wide?: boolean;
}

const { project, index, cover, wide = false } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<article class:list={['card', 'reveal', { 'card--wide': wide }]}>
  <div class="media">
    <Image
      src={cover}
      alt={`${project.title} — ${project.discipline}`}
      widths={wide ? [640, 1080, 1600, 2000] : [480, 800, 1200]}
      sizes={wide ? '(max-width: 720px) 100vw, 92vw' : '(max-width: 720px) 100vw, 46vw'}
      loading={index === 0 ? 'eager' : 'lazy'}
    />
  </div>
  <div class="meta">
    <h3><span class="num">{num}</span>{project.title}</h3>
    <span class="tail">{project.discipline} &middot; {project.year}</span>
  </div>
  <a class="cover-link" href={`/work/${project.slug}`} aria-label={`View ${project.title} project`}
  ></a>
</article>

<style>
  .card {
    position: relative;
  }

  .media {
    overflow: hidden;
    background: var(--line);
  }

  .media img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    transition: transform 600ms var(--ease-out);
  }

  .card--wide .media img {
    aspect-ratio: 21 / 10;
  }

  .card:hover .media img {
    transform: scale(1.03);
  }

  .meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
  }

  .meta h3 {
    font-size: var(--text-h3);
  }

  .num {
    color: var(--accent-ink);
    font-size: 0.7em;
    font-variant-numeric: tabular-nums;
    vertical-align: 0.25em;
    margin-right: 0.9em;
  }

  .tail {
    font-size: 0.8rem;
    color: var(--ink-soft);
    text-align: right;
    white-space: nowrap;
  }

  .card:hover .meta h3 {
    color: var(--accent-ink);
  }

  .cover-link {
    position: absolute;
    inset: 0;
  }

  @media (max-width: 540px) {
    .tail {
      white-space: normal;
    }
  }
</style>

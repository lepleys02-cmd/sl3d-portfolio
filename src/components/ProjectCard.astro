---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index: number;
  cover: ImageMetadata;
  /** Full-width cards get larger responsive image slots. */
  wide?: boolean;
}

const { project, index, cover, wide = false } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<article class:list={['card', 'reveal', { 'card--wide': wide }]} data-peek="View case study →">
  <div class="media">
    <Image
      src={cover}
      alt={`${project.title} — ${project.discipline}`}
      widths={wide ? [640, 1080, 1600, 2000] : [480, 800, 1200]}
      sizes={wide ? '(max-width: 720px) 100vw, 92vw' : '(max-width: 720px) 100vw, 46vw'}
      loading={index === 0 ? 'eager' : 'lazy'}
    />
    {
      project.previewVideo && (
        <video
          class="preview"
          muted
          loop
          playsinline
          preload="none"
          src={project.previewVideo}
          aria-hidden="true"
        />
      )
    }
  </div>
  <div class="meta">
    <h3><span class="num">{num}</span>{project.title}</h3>
  </div>
  <a class="cover-link" href={`/work/${project.slug}`} aria-label={`View ${project.title} project`}
  ></a>
</article>

<style>
  .card {
    position: relative;
  }

  .media {
    overflow: hidden;
    background: var(--line);
  }

  .media img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    transition: transform 600ms var(--ease-out);
  }

  .card--wide .media img {
    aspect-ratio: 21 / 10;
  }

  .card:hover .media img {
    transform: scale(1.03);
  }

  .preview {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 500ms var(--ease-out);
    pointer-events: none;
  }

  .preview.is-playing {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .preview.is-playing {
      opacity: 0;
    }
  }

  .media {
    position: relative;
  }

  .meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
  }

  .meta h3 {
    font-size: var(--text-h3);
  }

  .num {
    color: var(--accent-ink);
    font-size: 0.7em;
    font-variant-numeric: tabular-nums;
    vertical-align: 0.25em;
    margin-right: 0.9em;
  }

  .card:hover .meta h3 {
    color: var(--accent-ink);
  }

  .cover-link {
    position: absolute;
    inset: 0;
  }

  /* .cover-link is an invisible full-card overlay, so its own default
     :focus-visible outline reads as unstyled. Ring the card instead and
     suppress the link's own outline to avoid a doubled ring. */
  .card:has(.cover-link:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Only suppress the link's own ring where :has() can re-draw it on the
     card — otherwise keyboard users would get no focus indicator at all. */
  @supports selector(:has(a)) {
    .cover-link:focus-visible {
      outline: none;
    }
  }

</style>

<script>
  // Preview videos autoplay/loop on their own — no hover needed. Nothing
  // downloads until a card nears the viewport (preload="none" + this
  // observer), and playback pauses again once it scrolls away, so at most
  // a couple of cards are decoding video at once. Reduced-motion users
  // never see the video layer (poster stays put; see the CSS override).
  function initPreviews() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const previews = document.querySelectorAll<HTMLVideoElement>(
      '.card video.preview:not([data-wired])'
    );
    if (!previews.length) return;

    if (!('IntersectionObserver' in window)) {
      previews.forEach((preview) => {
        preview.dataset.wired = 'true';
        preview.classList.add('is-playing');
        preview.play().catch(() => preview.classList.remove('is-playing'));
      });
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const preview = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            preview.classList.add('is-playing');
            preview.play().catch(() => preview.classList.remove('is-playing'));
          } else {
            preview.pause();
          }
        }
      },
      { threshold: 0.35 }
    );

    previews.forEach((preview) => {
      preview.dataset.wired = 'true';
      io.observe(preview);
    });
  }

  document.addEventListener('astro:page-load', initPreviews);
</script>

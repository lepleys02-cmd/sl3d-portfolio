---
import { Image } from 'astro:assets';
import { software } from '../data/software';

// Render the set twice back-to-back so a -50% translate loop is seam-free.
const track = [...software, ...software];
---

<div class="wrap marquee-wrap reveal">
  <p class="label kicker">Tools of the trade</p>
  <div class="marquee" role="group" aria-label="Software I work with">
    <div class="track">
      {
        track.map((tool, i) => {
          const isDuplicate = i >= software.length;
          return (
            <a
              class="logo"
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              style={`--brand: ${tool.brandColor};`}
              tabindex={isDuplicate ? -1 : 0}
              aria-hidden={isDuplicate ? 'true' : undefined}
            >
              <Image
                class="mark"
                src={tool.logo}
                alt={`${tool.name} logo`}
                width={40}
                height={40}
                loading="lazy"
                decoding="async"
              />
              <span class="tip" aria-hidden="true">{tool.name}</span>
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  .marquee-wrap {
    /* Bottom padding is trimmed by exactly the headroom .marquee gains below
       for the tooltip pill, so the section's net height/rhythm is unchanged
       — see .marquee's padding-bottom below. */
    padding-top: var(--space-block);
    padding-bottom: max(0rem, calc(var(--space-block) - 2.5rem));
  }

  .kicker {
    margin-bottom: 1.6rem;
  }

  .marquee {
    overflow: hidden;
    /* Headroom for the .tip pill, which sits below the tile and would
       otherwise be sliced by this box's own overflow:hidden. */
    padding-bottom: 2.5rem;
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .track {
    display: flex;
    width: max-content;
    gap: clamp(1.75rem, 4vw, 3.25rem);
    animation: scroll-track 32s linear infinite;
  }

  .marquee:hover .track,
  .marquee:focus-within .track {
    animation-play-state: paused;
  }

  @keyframes scroll-track {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .logo {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    background: transparent;
    transition: background var(--duration-fast) ease;
  }

  /* Name-only tooltip, styled like ShowcaseTile's .cue badge minus the
     accent dot. Sits below the tile with room reserved by .marquee's
     padding-bottom above. */
  .tip {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 50%;
    z-index: 2;
    padding: 0.28em 0.7em;
    font-family: var(--font-display);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--ink);
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    border: 1px solid var(--line-strong);
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -4px);
    transition:
      opacity var(--duration-fast) ease,
      transform var(--duration-fast) ease;
  }

  .logo:hover .tip,
  .logo:focus-visible .tip {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  /* Fallback for engines without color-mix() support: a quiet neutral ink
     wash (not the full-strength brand hex — that reads as a loud, opaque
     block). Browsers that support color-mix() override it with the softer,
     per-brand tint on the next line. */
  .logo:hover,
  .logo:focus-visible {
    background: rgba(22, 21, 15, 0.06);
    background: color-mix(in srgb, var(--brand) 10%, transparent);
  }

  /* Real, full-color vendor logos. Default state desaturates with plain
     grayscale(1) only — no brightness/contrast crush layered on top, which
     is what made iteration 1's mono state collapse into near-identical dark
     blocks. grayscale(1) preserves each logo's internal luminance contrast
     (light glyph vs. dark tile, etc.), so the row stays legible as distinct
     gray marks. Hover removes the filter to reveal true brand color. */
  .mark {
    display: block;
    width: 40px;
    height: 40px;
    filter: grayscale(1);
    transition:
      filter var(--duration-fast) ease,
      transform var(--duration-fast) ease;
  }

  .logo:hover .mark,
  .logo:focus-visible .mark {
    filter: none;
    transform: translateY(-3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
      width: auto;
      flex-wrap: wrap;
      justify-content: center;
    }

    /* The duplicated half exists only to feed the marquee loop; hide it so
       the static row shows each tool once. */
    .track .logo[aria-hidden='true'] {
      display: none;
    }

    .logo,
    .mark,
    .tip {
      transition: none;
    }
  }
</style>

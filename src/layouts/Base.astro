---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Hide the big footer CTA on pages that are themselves a CTA (contact). */
  compactFooter?: boolean;
}

const { title, description, compactFooter = false } = Astro.props;
const site = Astro.site ?? new URL('https://sl3d.net');
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL('/og.jpg', site);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SL3D — Sam Lepley" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23f7f6f2'/%3E%3Cpath d='M6 22 16 6l10 16z' fill='none' stroke='%23c14a0a' stroke-width='2.5'/%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;560;600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <slot />
    <Footer compact={compactFooter} />

    <script>
      // Scroll-reveal: purely progressive enhancement. Reduced-motion users
      // get static content via the CSS media query. Re-runs after every
      // view-transition navigation (astro:page-load fires on initial load too).
      function initReveal() {
        const items = document.querySelectorAll('.reveal:not(.is-visible)');
        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: '0px 0px -5% 0px' }
          );
          items.forEach((el) => io.observe(el));
        } else {
          items.forEach((el) => el.classList.add('is-visible'));
        }
      }
      // Cursor-following "peek" pill: appears while hovering a card that
      // opts in via data-peek, tracking the cursor with a direct 1:1 follow
      // (no lerp/inertia — trailing motion fights the site's restrained
      // voice). Desktop-with-a-mouse only; a no-op on touch or when
      // reduced-motion is requested. The pill element and its pointer
      // listeners are set up once (module-scope `peekWired` flag): the
      // ClientRouter swaps <body> content on every navigation, which would
      // otherwise orphan the appended pill, so each astro:page-load
      // re-creates it if missing without re-attaching duplicate listeners.
      let peekPill: HTMLDivElement | null = null;
      let peekWired = false;
      let peekRaf = 0;
      let peekX = 0;
      let peekY = 0;

      function movePeekPill() {
        peekRaf = 0;
        if (!peekPill) return;
        const offset = 18;
        const edge = 8;
        const maxX = window.innerWidth - peekPill.offsetWidth - edge;
        const maxY = window.innerHeight - peekPill.offsetHeight - edge;
        const x = Math.min(Math.max(peekX + offset, edge), Math.max(maxX, edge));
        const y = Math.min(Math.max(peekY + offset, edge), Math.max(maxY, edge));
        peekPill.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      }

      function initPeekPill() {
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        if (!peekPill || !document.body.contains(peekPill)) {
          peekPill = document.createElement('div');
          peekPill.className = 'peek-pill';
          peekPill.setAttribute('aria-hidden', 'true');
          peekPill.innerHTML = '<span class="peek-pill-inner"></span>';
          document.body.appendChild(peekPill);
        }

        if (peekWired) return;
        peekWired = true;

        document.addEventListener('pointerover', (event) => {
          const card = (event.target as HTMLElement).closest<HTMLElement>('.card[data-peek]');
          if (!card || !peekPill) return;
          const inner = peekPill.querySelector('.peek-pill-inner');
          if (inner) inner.textContent = card.dataset.peek ?? '';
          peekPill.classList.add('is-active');
        });

        document.addEventListener('pointermove', (event) => {
          peekX = event.clientX;
          peekY = event.clientY;
          if (!peekRaf) peekRaf = requestAnimationFrame(movePeekPill);
        });

        document.addEventListener('pointerout', (event) => {
          const card = (event.target as HTMLElement).closest<HTMLElement>('.card[data-peek]');
          if (!card || !peekPill) return;
          const related = event.relatedTarget as HTMLElement | null;
          if (related && card.contains(related)) return;
          peekPill.classList.remove('is-active');
        });
      }

      document.addEventListener('astro:page-load', initReveal);
      document.addEventListener('astro:page-load', initPeekPill);
    </script>
  </body>
</html>

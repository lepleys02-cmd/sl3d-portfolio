---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact — Sam Lepley | SL3D"
  description="Get in touch with Sam Lepley (SL3D) for 3D visualisation, CAD floor plans and product animation."
  compactFooter
>
  <main>
    <section class="wrap layout">
      <div class="intro-col">
        <p class="label label--accent reveal">Contact</p>
        <h1 class="reveal">Have a project? <em>Let&rsquo;s talk.</em></h1>
        <p class="intro reveal">
          Send a message or email directly &mdash; I usually reply within one working day.
        </p>
        <div class="actions reveal">
          <a class="btn btn--primary" href="mailto:sam@sl3d.net">Email &rarr;</a>
          <a
            class="linkedin-btn"
            href="https://www.linkedin.com/in/sam-lepley-7389b0180/"
            target="_blank"
            rel="noopener"
            aria-label="Sam Lepley on LinkedIn"
          >
            <svg viewBox="0 0 24 24" width="44" height="44" aria-hidden="true" focusable="false">
              <rect width="24" height="24" rx="4" fill="#0A66C2" />
              <path
                fill="#fff"
                d="M7.12 9H3.56v11.45h3.56V9zM5.34 7.43a2.07 2.07 0 1 0 0-4.14 2.07 2.07 0 0 0 0 4.14zM20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.44-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29z"
              />
            </svg>
          </a>
        </div>
        <p class="based reveal">
          Based in the south of the Netherlands &mdash; working remotely across Europe.
        </p>
      </div>

      <form class="reveal" action="https://formsubmit.co/lepleys02@gmail.com" method="POST">
        <input type="hidden" name="_subject" value="New enquiry via sl3d portfolio" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="message">Project</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Send message &rarr;</button>
      </form>
    </section>
  </main>
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 26rem) 1fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: start;
    padding-block: calc(var(--space-section) * 0.55) var(--space-block);
  }

  .intro-col .label {
    margin-bottom: 1.4rem;
  }

  .intro-col h1 {
    font-size: var(--text-h1);
    max-width: 12ch;
  }

  .intro-col h1 em {
    font-style: normal;
    color: var(--accent-ink);
  }

  .intro {
    color: var(--ink-soft);
    margin-top: 1.4rem;
    max-width: 30ch;
  }

  /* Email box + LinkedIn logo share one row, vertically centered, with a
     comfortable gap between them. */
  .actions {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
    margin-top: 1.8rem;
  }

  .actions .btn {
    margin-top: 0;
  }

  /* LinkedIn logo button — the brand bug links straight to the profile. */
  .linkedin-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    border-radius: 6px;
    transition:
      transform var(--duration-fast) ease,
      box-shadow var(--duration-fast) ease;
  }

  .linkedin-btn svg {
    display: block;
  }

  .linkedin-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(10, 102, 194, 0.28);
  }

  .linkedin-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .based {
    margin-top: 1.6rem;
    font-size: 0.9rem;
    color: var(--ink-soft);
    max-width: 26rem;
  }

  form {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }

  .field {
    display: grid;
    gap: 0.45rem;
    margin-bottom: 1.5rem;
  }

  label {
    font-family: var(--font-display);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  input,
  textarea {
    font: inherit;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--line-strong);
    padding: 0.8rem 1rem;
    border-radius: 0;
    transition: border-color var(--duration-fast) ease;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  textarea {
    resize: vertical;
  }

  form .btn {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 860px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact — Sam Lepley | SL3D"
  description="Get in touch with Sam Lepley (SL3D) for 3D visualisation, CAD floor plans and product animation."
  compactFooter
>
  <main>
    <section class="wrap layout">
      <div class="intro-col">
        <p class="label label--accent reveal">Contact</p>
        <h1 class="reveal">Have a project? <em>Let&rsquo;s talk.</em></h1>
        <p class="intro reveal">
          Send a message or email directly &mdash; I usually reply within one working day.
        </p>
        <a class="btn btn--primary reveal" href="mailto:lepleys02@gmail.com">
          lepleys02@gmail.com &rarr;
        </a>
        <a
          class="arrow-link reveal elsewhere"
          href="https://www.linkedin.com/in/sam-lepley-7389b0180/"
          target="_blank"
          rel="noopener">LinkedIn &nearr;</a
        >
        <p class="based reveal">
          Based in the south of the Netherlands &mdash; working remotely across Europe.
        </p>
        <figure class="signature reveal" aria-label="SL3D signature animation">
          <video autoplay muted loop playsinline preload="metadata" poster="/video/hero-poster-v2.jpg">
            <source src="/video/hero-loop-v2.mp4" type="video/mp4" />
          </video>
          <figcaption class="label">The signature</figcaption>
        </figure>
      </div>

      <form class="reveal" action="https://formsubmit.co/lepleys02@gmail.com" method="POST">
        <input type="hidden" name="_subject" value="New enquiry via sl3d portfolio" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="message">Project</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Send message &rarr;</button>
      </form>
    </section>
  </main>
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 26rem) 1fr;
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: start;
    padding-block: calc(var(--space-section) * 0.55) var(--space-block);
  }

  .intro-col .label {
    margin-bottom: 1.4rem;
  }

  .intro-col h1 {
    font-size: var(--text-h1);
    max-width: 12ch;
  }

  .intro-col h1 em {
    font-style: normal;
    color: var(--accent-ink);
  }

  .intro {
    color: var(--ink-soft);
    margin-top: 1.4rem;
    max-width: 30ch;
  }

  .intro-col .btn {
    margin-top: 1.8rem;
  }

  .elsewhere {
    display: inline-flex;
    margin-top: 1.6rem;
  }

  .based {
    margin-top: 1.6rem;
    font-size: 0.9rem;
    color: var(--ink-soft);
    max-width: 26rem;
  }

  .signature {
    margin: 2.4rem 0 0;
  }

  .signature video {
    display: block;
    width: min(100%, 13rem);
    aspect-ratio: 1;
    height: auto;
    border: 1px solid var(--line);
  }

  .signature figcaption {
    margin-top: 0.7rem;
  }

  form {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }

  .field {
    display: grid;
    gap: 0.45rem;
    margin-bottom: 1.5rem;
  }

  label {
    font-family: var(--font-display);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  input,
  textarea {
    font: inherit;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--line-strong);
    padding: 0.8rem 1rem;
    border-radius: 0;
    transition: border-color var(--duration-fast) ease;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  textarea {
    resize: vertical;
  }

  form .btn {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 860px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }
</style>

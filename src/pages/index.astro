---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
import portrait from '../assets/about/portrait.jpg';

const covers = import.meta.glob<{ default: ImageMetadata }>('../assets/covers/*.jpg', {
  eager: true,
});

function coverFor(slug: string): ImageMetadata {
  const entry = covers[`../assets/covers/${slug}.jpg`];
  if (!entry) throw new Error(`Missing cover image for project "${slug}"`);
  return entry.default;
}

const steps = [
  {
    title: 'Understand',
    text: 'Drawings, product data, mood references — I start from what the project actually needs to communicate.',
  },
  {
    title: 'Model',
    text: 'Accurate 3D geometry and CAD-clean technical drawings, built to real dimensions.',
  },
  {
    title: 'Render',
    text: 'Photorealistic stills, 360° panoramas and animation — materials and light treated like photography.',
  },
  {
    title: 'Deliver',
    text: 'Print- and web-ready files, revisions included, on the agreed date.',
  },
];
---

<Base
  title="Sam Lepley — SL3D | 3D Visualisation & CAD"
  description="Sam Lepley (SL3D) — 3D visualisation, photorealistic rendering, CAD floor plans and product animation from the south of the Netherlands. Clarity you can build from."
>
  <main>
    <!-- Statement hero (UNStudio pattern): type first, image after -->
    <section class="hero wrap" aria-label="Introduction">
      <p class="label label--accent reveal">Sam Lepley &mdash; CAD Specialist</p>
      <h1 class="reveal">SL3D<sup class="brand-mark">&#9650;</sup></h1>
      <div class="hero-row reveal">
        <p>Clarity you can build from.</p>
        <a class="arrow-link" href="#work">Selected work &darr;</a>
      </div>
    </section>

    <section class="hero-media reveal" aria-label="Showreel: SL3D signature animation — the logo carving through snow">
      <!-- Floor plan schematic (decorative) -->
      <svg class="schematic" width="320" height="400" viewBox="0 0 320 400" fill="none" stroke="currentColor" aria-hidden="true">
        <rect x="50" y="70" width="220" height="220" stroke-width="1.4" />
        <rect x="58" y="78" width="204" height="204" stroke-width="0.8" />
        <line x1="170" y1="78" x2="170" y2="190" stroke-width="1.4" />
        <line x1="170" y1="190" x2="262" y2="190" stroke-width="1.4" />
        <rect x="90" y="68" width="40" height="12" stroke-width="0.8" />
        <line x1="90" y1="74" x2="130" y2="74" stroke-width="0.8" />
        <line x1="130" y1="290" x2="130" y2="250" stroke-width="0.8" />
        <path d="M130 250 A40 40 0 0 1 170 290" stroke-width="0.8" stroke-dasharray="3 3" />
        <line x1="30" y1="180" x2="290" y2="180" stroke-width="0.6" stroke-dasharray="10 4 2 4" />
        <line x1="160" y1="50" x2="160" y2="310" stroke-width="0.6" stroke-dasharray="10 4 2 4" />
        <line x1="50" y1="330" x2="270" y2="330" stroke-width="0.8" />
        <line x1="46" y1="334" x2="54" y2="326" stroke-width="0.8" />
        <line x1="266" y1="334" x2="274" y2="326" stroke-width="0.8" />
        <text x="160" y="348" text-anchor="middle" stroke="none" fill="currentColor" font-size="10" letter-spacing="1.5">6 200</text>
        <line x1="300" y1="70" x2="300" y2="290" stroke-width="0.8" />
        <line x1="296" y1="74" x2="304" y2="66" stroke-width="0.8" />
        <line x1="296" y1="294" x2="304" y2="286" stroke-width="0.8" />
        <text transform="rotate(90 312 180)" x="312" y="180" text-anchor="middle" stroke="none" fill="currentColor" font-size="10" letter-spacing="1.5">5 400</text>
      </svg>

      <video
        class="hero-video"
        muted
        loop
        playsinline
        preload="auto"
        poster="/video/hero-poster-v2.jpg"
      >
        <source src="/video/hero-loop-v2.mp4" type="video/mp4" />
      </video>

      <!-- Elevation schematic (decorative) -->
      <svg class="schematic" width="320" height="400" viewBox="0 0 320 400" fill="none" stroke="currentColor" aria-hidden="true">
        <line x1="20" y1="320" x2="300" y2="320" stroke-width="1.4" />
        <g stroke-width="0.6">
          <line x1="30" y1="320" x2="22" y2="330" /><line x1="55" y1="320" x2="47" y2="330" />
          <line x1="80" y1="320" x2="72" y2="330" /><line x1="105" y1="320" x2="97" y2="330" />
          <line x1="130" y1="320" x2="122" y2="330" /><line x1="155" y1="320" x2="147" y2="330" />
          <line x1="180" y1="320" x2="172" y2="330" /><line x1="205" y1="320" x2="197" y2="330" />
          <line x1="230" y1="320" x2="222" y2="330" /><line x1="255" y1="320" x2="247" y2="330" />
          <line x1="280" y1="320" x2="272" y2="330" />
        </g>
        <path d="M70 320 V180 L160 120 L250 180 V320" stroke-width="1.4" />
        <path d="M78 186 L160 128 L242 186" stroke-width="0.8" />
        <rect x="100" y="240" width="34" height="80" stroke-width="0.8" />
        <rect x="170" y="220" width="50" height="50" stroke-width="0.8" />
        <line x1="195" y1="220" x2="195" y2="270" stroke-width="0.6" />
        <line x1="170" y1="245" x2="220" y2="245" stroke-width="0.6" />
        <path d="M96 180 A 30 30 0 0 1 92 198" stroke-width="0.8" />
        <text x="106" y="200" stroke="none" fill="currentColor" font-size="10" letter-spacing="1.5">35&deg;</text>
        <line x1="160" y1="100" x2="160" y2="335" stroke-width="0.6" stroke-dasharray="10 4 2 4" />
        <line x1="280" y1="120" x2="280" y2="320" stroke-width="0.8" />
        <line x1="276" y1="124" x2="284" y2="116" stroke-width="0.8" />
        <line x1="276" y1="324" x2="284" y2="316" stroke-width="0.8" />
        <text transform="rotate(90 292 220)" x="292" y="220" text-anchor="middle" stroke="none" fill="currentColor" font-size="10" letter-spacing="1.5">2 800</text>
      </svg>
    </section>

    <!-- Selected work: editorial rhythm — full, half/half, full -->
    <section class="section wrap" id="work" aria-labelledby="work-heading">
      <div class="section-head reveal">
        <h2 id="work-heading">Selected work</h2>
        <span class="count">{String(projects.length).padStart(2, '0')} projects</span>
      </div>
      <div class="work-grid">
        {
          projects.map((project, i) => (
            <ProjectCard
              project={project}
              index={i}
              cover={coverFor(project.slug)}
              wide={i === 0 || i === projects.length - 1}
            />
          ))
        }
      </div>
    </section>

    <!-- Process strip (Vision Scapes pattern) -->
    <section class="section wrap" aria-labelledby="process-heading">
      <div class="section-head reveal">
        <h2 id="process-heading">How I work</h2>
        <span class="count">04 steps</span>
      </div>
      <ol class="steps">
        {
          steps.map((step, i) => (
            <li class="reveal">
              <span class="step-num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- About strip -->
    <section class="section wrap" aria-label="About Sam Lepley">
      <div class="about-strip reveal">
        <Image src={portrait} alt="Portrait of Sam Lepley" widths={[320, 500]} sizes="(max-width: 720px) 40vw, 220px" />
        <div>
          <p class="label label--accent">About</p>
          <blockquote>
            From managing construction sites in South Africa to 3D visualisation in the Netherlands
            &mdash; <em>&ldquo;he who dares, wins.&rdquo;</em>
          </blockquote>
          <a class="arrow-link" href="/about">Read the full story &rarr;</a>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .hero {
    padding-block: calc(var(--space-section) * 0.7) calc(var(--space-section) * 0.45);
  }

  .hero .label {
    margin-bottom: 1.6rem;
  }

  .hero h1 {
    font-size: var(--text-hero);
    max-width: 12ch;
  }

  .hero h1 .brand-mark {
    font-size: 0.32em;
    color: var(--accent-ink);
    vertical-align: super;
    letter-spacing: 0;
  }

  .hero-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem 3rem;
    margin-top: clamp(1.8rem, 4vw, 3.2rem);
  }

  .hero-row p {
    max-width: 34rem;
    color: var(--ink-soft);
  }

  /* Square signature animation centred, flanked by decorative technical
     schematics — the full square frame stays visible; never crop it. */
  .hero-media {
    display: grid;
    grid-template-columns: 1fr min(clamp(20rem, 68vh, 40rem), 60vw) 1fr;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 4.5rem);
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .hero-media video {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
  }

  .schematic {
    width: 100%;
    max-width: 20rem;
    justify-self: center;
    color: var(--ink-soft);
    opacity: 0.5;
  }

  .schematic text {
    font-family: var(--font-display);
  }

  @media (max-width: 900px) {
    .hero-media {
      grid-template-columns: 1fr;
    }

    .schematic {
      display: none;
    }
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3.5vw, 3.5rem) clamp(1.25rem, 2.5vw, 2.5rem);
  }

  .work-grid > :global(.card--wide) {
    grid-column: 1 / -1;
  }

  .steps {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .steps li {
    border-top: 1px solid var(--line-strong);
    padding-top: 1.1rem;
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--accent-ink);
    font-variant-numeric: tabular-nums;
  }

  .steps h3 {
    font-size: var(--text-h3);
    margin-block: 0.5rem 0.6rem;
  }

  .steps p {
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  .about-strip {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 4rem);
    border-top: 1px solid var(--ink);
    padding-top: var(--space-block);
  }

  .about-strip img {
    width: clamp(8rem, 18vw, 13.75rem);
    aspect-ratio: 1;
    object-fit: cover;
    flex-shrink: 0;
  }

  .about-strip blockquote {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 560;
    line-height: 1.15;
    letter-spacing: -0.02em;
    max-width: 26ch;
    margin-block: 0.9rem 1.4rem;
  }

  .about-strip em {
    color: var(--accent-ink);
    font-style: normal;
  }

  @media (max-width: 720px) {
    .work-grid,
    .steps {
      grid-template-columns: 1fr;
    }

    .about-strip {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (min-width: 721px) and (max-width: 1023px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  // Hero loop: autoplay only when the user hasn't asked for reduced motion.
  // Without JS (or with reduced motion) the poster frame stands in.
  document.addEventListener('astro:page-load', () => {
    const video = document.querySelector<HTMLVideoElement>('.hero-video');
    if (!video) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    video.play().catch(() => {
      /* Autoplay blocked — poster remains, which is fine. */
    });
  });
</script>

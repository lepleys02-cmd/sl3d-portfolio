---
import type { ImageMetadata } from 'astro';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects, collections } from '../data/projects';

const collection = collections.find((c) => c.slug === 'ai')!;
const members = projects.filter((p) => p.collection === collection.slug);

const covers = import.meta.glob<{ default: ImageMetadata }>('../assets/covers/*.jpg', {
  eager: true,
});
function coverFor(slug: string): ImageMetadata {
  const entry = covers[`../assets/covers/${slug}.jpg`];
  if (!entry) throw new Error(`Missing cover image for "${slug}"`);
  return entry.default;
}

// One line per pipeline stage, paired by index with collection.facets.
// Deliberately intent-level: the stages say what happens, never how.
const stageNotes = [
  'What the image has to say, and for whom — set before any tool is opened.',
  'Every scene starts from geometry built to real product dimensions.',
  'Light, atmosphere and grade are pushed in short, directed passes.',
  'Most iterations are discarded. The keepers are corrected by hand.',
  'The result is checked against the source model before it ships.',
];
const stages = collection.facets.map((name, i) => ({ name, note: stageNotes[i] ?? '' }));
---

<Base
  title={`${collection.title} — Sam Lepley | SL3D`}
  description={collection.description}
>
  <main>
    <section class="hub-hero wrap">
      <p class="label label--accent reveal">{collection.kicker}</p>
      <h1 class="reveal">{collection.title}</h1>
      <p class="intro reveal">{collection.intro}</p>
      <ul class="facets reveal" aria-label="Production pipeline">
        {
          stages.map((stage, i) => (
            <li>
              <span class="facet-num">{String(i + 1).padStart(2, '0')}</span>
              <span>{stage.name}</span>
              <span class="facet-note">{stage.note}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="hub-work wrap" aria-label={`${collection.title} projects`}>
      <div class="work-grid">
        {
          members.map((project, i) => (
            <ProjectCard project={project} index={i} cover={coverFor(project.slug)} />
          ))
        }
      </div>
    </section>

    <nav class="hub-nav wrap" aria-label="Back to work">
      <a href="/#work">
        <span class="label">&larr; All work</span>
        <span class="name">Selected work</span>
      </a>
    </nav>
  </main>
</Base>

<style>
  .hub-hero {
    padding-block: calc(var(--space-section) * 0.55) var(--space-block);
  }

  .hub-hero .label {
    margin-bottom: 1.4rem;
  }

  .hub-hero h1 {
    font-size: var(--text-h1);
    max-width: 16ch;
  }

  .intro {
    max-width: var(--max-prose);
    color: var(--ink-soft);
    margin-top: 1.4rem;
  }

  .facets {
    list-style: none;
    padding: 0;
    margin-top: var(--space-block);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }

  .facets li {
    border-top: 1px solid var(--line-strong);
    padding-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--ink);
  }

  .facet-num {
    font-size: 0.8rem;
    color: var(--accent-ink);
    font-variant-numeric: tabular-nums;
  }

  .facet-note {
    font-family: var(--font-body, inherit);
    font-weight: 400;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .hub-work {
    padding-bottom: var(--space-block);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3.5vw, 3.5rem) clamp(1.25rem, 2.5vw, 2.5rem);
  }

  .work-grid > :global(.card--wide) {
    grid-column: 1 / -1;
  }

  .hub-nav {
    border-top: 1px solid var(--ink);
    margin-top: var(--space-block);
    padding-top: 1.4rem;
  }

  .hub-nav a {
    display: grid;
    gap: 0.4rem;
  }

  .hub-nav .name {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: var(--text-h3);
    transition: color var(--duration-fast) ease;
  }

  .hub-nav a:hover .name {
    color: var(--accent-ink);
  }

  @media (max-width: 720px) {
    .facets,
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

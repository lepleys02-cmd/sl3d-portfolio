---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../../layouts/Base.astro';
import { projects, collections } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug);
if (!project) throw new Error(`Unknown project slug "${slug}"`);

// Collection members cycle prev/next among their siblings and link back up to
// the hub; standalone projects cycle among the other standalone projects.
const parent = project.collection
  ? collections.find((c) => c.slug === project.collection)
  : undefined;
const ring = project.collection
  ? projects.filter((p) => p.collection === project.collection)
  : projects.filter((p) => !p.collection);
const ri = ring.findIndex((p) => p.slug === slug);
const prev = ring[(ri - 1 + ring.length) % ring.length];
const next = ring[(ri + 1) % ring.length];
const num = String(ri + 1).padStart(2, '0');
const total = String(ring.length).padStart(2, '0');

const allImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/**/*.jpg', {
  eager: true,
});
const projectImages = Object.entries(allImages)
  .filter(([path]) => path.includes(`/assets/${project.slug}/`))
  .sort(([a], [b]) => a.localeCompare(b));

// Drawing-vs-render pairing: pulled out of the normal gallery flow.
const processImages = project.process
  ? {
      before: projectImages.find(([path]) => path.endsWith(`/${project.process!.before}`))?.[1]
        .default,
      after: projectImages.find(([path]) => path.endsWith(`/${project.process!.after}`))?.[1]
        .default,
    }
  : undefined;
const processFiles = project.process ? [project.process.before, project.process.after] : [];
const gallery = projectImages
  .filter(([path]) => !processFiles.some((file) => path.endsWith(`/${file}`)))
  .map(([, mod]) => mod.default);

// Drawing-led case studies pair each sorted sheet with its label + caption.
const sheetItems =
  project.documentation && project.sheets
    ? gallery.map((img, i) => ({ img, meta: project.sheets![i] }))
    : [];
---

<Base
  title={`${project.title} — Sam Lepley | SL3D`}
  description={`${project.title}: ${project.description}`}
>
  <main>
    <section class="project-hero wrap">
      <p class="label label--accent reveal">
        {
          parent ? (
            <>
              <a class="hub-back" href={`/${parent.slug}`}>
                {parent.title}
              </a>{' '}
              &mdash; {project.discipline}
            </>
          ) : (
            <>
              {num} / {total} &mdash; {project.discipline}
            </>
          )
        }
      </p>
      <h1 class="reveal">{project.title}</h1>
      <p class="intro reveal">{project.description}</p>
      <dl class="facts reveal">
        {
          project.facts.map((fact) => (
            <div>
              <dt class="label">{fact.k}</dt>
              <dd>{fact.v}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    {
      project.headerVideo && (
        <section class="header-media wrap reveal" aria-label={`${project.title} showreel`}>
          <video
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            poster={project.headerVideo.replace('.mp4', '-poster.jpg')}
          >
            <source src={project.headerVideo} type="video/mp4" />
          </video>
        </section>
      )
    }

    {
      (project.brief || project.approach) && (
        <section class="case wrap" aria-label="Case study">
          {project.brief && (
            <div class="reveal">
              <p class="label label--accent">Brief</p>
              <p>{project.brief}</p>
            </div>
          )}
          {project.approach && (
            <div class="reveal">
              <p class="label label--accent">Approach</p>
              <p>{project.approach}</p>
            </div>
          )}
        </section>
      )
    }

    {
      project.process && processImages?.before && processImages?.after && (
        <section class="process wrap" aria-label="From drawing to render">
          <div class="process-pair">
            <figure class="reveal">
              <Image
                src={processImages.before}
                alt="Technical drawing sheet"
                widths={[640, 1080, 1600]}
                sizes="(max-width: 900px) 100vw, 46vw"
                loading="eager"
              />
              <figcaption class="label">Drawn</figcaption>
            </figure>
            <figure class="reveal">
              <Image
                src={processImages.after}
                alt="Photorealistic render of the same building"
                widths={[640, 1080, 1600]}
                sizes="(max-width: 900px) 100vw, 46vw"
                loading="eager"
              />
              <figcaption class="label">Rendered</figcaption>
            </figure>
          </div>
          <p class="process-caption reveal">{project.process.caption}</p>
        </section>
      )
    }

    {
      project.documentation && sheetItems.length > 0 ? (
        <section class="gallery gallery--sheets wrap" aria-label={`${project.title} drawing set`}>
          {sheetItems.map(({ img, meta }, i) => (
            <figure class="sheet reveal">
              <div class="sheet-frame">
                <Image
                  src={img}
                  alt={meta ? `${project.title} — ${meta.label}` : `${project.title} drawing ${i + 1}`}
                  widths={[640, 1080, 1600, 2000]}
                  sizes="(max-width: 900px) 100vw, 92vw"
                  loading={i < 1 ? 'eager' : 'lazy'}
                />
              </div>
              {meta && (
                <figcaption>
                  <span class="sheet-label">{meta.label}</span>
                  <span class="sheet-note">{meta.caption}</span>
                </figcaption>
              )}
            </figure>
          ))}
        </section>
      ) : (
        gallery.length > 0 && (
          <section class="gallery wrap" aria-label={`${project.title} gallery`}>
            {gallery.map((img, i) => (
              <figure class="reveal">
                <Image
                  src={img}
                  alt={`${project.title} visualisation ${i + 1}`}
                  widths={[640, 1080, 1600, 2000]}
                  sizes="(max-width: 900px) 100vw, 92vw"
                  loading={i < 1 ? 'eager' : 'lazy'}
                />
              </figure>
            ))}
          </section>
        )
      )
    }

    {
      project.videos && (
        <section class="videos wrap" aria-label={`${project.title} videos`}>
          {project.videos.map((src) => (
            <figure class="reveal">
              {/* eslint-disable-next-line */}
              <video controls preload="metadata" playsinline poster={src.replace('.mp4', '-poster.jpg')}>
                <source src={src} type="video/mp4" />
              </video>
            </figure>
          ))}
        </section>
      )
    }

    <nav class="project-nav wrap" aria-label="Project navigation">
      <a href={`/work/${prev.slug}`}>
        <span class="label">&larr; Previous</span>
        <span class="name">{prev.title}</span>
      </a>
      <a href={`/work/${next.slug}`} class="next">
        <span class="label">Next &rarr;</span>
        <span class="name">{next.title}</span>
      </a>
    </nav>
  </main>
</Base>

<style>
  .project-hero {
    padding-block: calc(var(--space-section) * 0.55) var(--space-block);
  }

  .project-hero .label {
    margin-bottom: 1.4rem;
  }

  .hub-back {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) ease;
  }

  .hub-back:hover {
    border-bottom-color: currentColor;
  }

  .project-hero h1 {
    font-size: var(--text-h1);
  }

  .intro {
    max-width: var(--max-prose);
    color: var(--ink-soft);
    margin-top: 1.4rem;
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 14rem));
    gap: 1.5rem;
    margin-top: var(--space-block);
  }

  .facts div {
    border-top: 1px solid var(--line-strong);
    padding-top: 0.8rem;
  }

  .facts dd {
    margin: 0.35rem 0 0;
    font-family: var(--font-display);
    font-weight: 500;
  }

  .header-media {
    margin-bottom: var(--space-block);
  }

  .header-media video {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--ink);
  }

  .case {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 3rem);
    margin-bottom: var(--space-block);
  }

  .case .label {
    margin-bottom: 0.8rem;
  }

  .case p:not(.label) {
    max-width: 36rem;
    color: var(--ink-soft);
  }

  .process {
    margin-bottom: var(--space-block);
  }

  .process-pair {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.25rem, 2.5vw, 2.5rem);
    align-items: center;
  }

  .process-pair figure {
    margin: 0;
  }

  .process-pair img {
    width: 100%;
    border: 1px solid var(--line);
  }

  .process-pair figcaption {
    margin-top: 0.7rem;
  }

  .process-caption {
    margin-top: 1.2rem;
    max-width: var(--max-prose);
    font-size: 0.92rem;
    color: var(--ink-soft);
  }

  /* Editorial rhythm: one full-bleed image, then a two-up pair */
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.25rem, 2.5vw, 2.5rem);
    align-items: start;
  }

  .gallery figure:nth-child(3n + 1) {
    grid-column: 1 / -1;
  }

  .gallery img {
    width: 100%;
  }

  /* Drawing-led projects: each sheet matted on paper with a hairline frame,
     a sheet label and a one-line curatorial note — reads as documentation,
     not a photo gallery. Shares the .gallery grid + full-bleed rhythm. */
  .gallery--sheets {
    align-items: start;
    row-gap: clamp(2rem, 4vw, 3.5rem);
  }

  .sheet {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .sheet-frame {
    background: var(--surface);
    border: 1px solid var(--line-strong);
    padding: clamp(0.7rem, 1.8vw, 1.6rem);
  }

  .sheet-frame img {
    width: 100%;
    display: block;
  }

  .gallery--sheets figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 0.85rem;
  }

  .sheet-label {
    font-family: var(--font-display);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }

  .sheet-note {
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 56ch;
  }

  .videos {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
  }

  .videos video {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--ink);
  }

  .project-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid var(--ink);
    margin-top: var(--space-section);
    padding-top: 1.4rem;
  }

  .project-nav a {
    display: grid;
    gap: 0.4rem;
  }

  .project-nav .next {
    text-align: right;
  }

  .project-nav .name {
    font-family: var(--font-display);
    font-weight: 560;
    font-size: var(--text-h3);
    transition: color var(--duration-fast) ease;
  }

  .project-nav a:hover .name {
    color: var(--accent-ink);
  }

  @media (max-width: 720px) {
    .gallery {
      grid-template-columns: 1fr;
    }

    .case,
    .process-pair {
      grid-template-columns: 1fr;
    }

    .gallery figure:nth-child(3n + 1) {
      grid-column: auto;
    }

    .facts {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
